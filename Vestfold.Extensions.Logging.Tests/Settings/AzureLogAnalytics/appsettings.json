{
  "AppName": "AzureLogAnalytics",
  "AppVersion": "1.2.3",
  "Serilog": {
    "AzureLogAnalytics": {
      "ClientId": "client-id",
      "ClientSecret": "client-secret",
      "Endpoint": "endpoint",
      "ImmutableId": "immutable-id",
      "StreamName": "stream-name",
      "TenantId": "tenant-id",
      "MinimumLevel": "Warning",
      "BatchSize": 50,
      "BufferSize": 500,
      "PeriodSeconds": 10
    },
    "MinimumLevel": {
      "Override": {
        "Microsoft.Hosting": "Error"
      }
    }
  }
}