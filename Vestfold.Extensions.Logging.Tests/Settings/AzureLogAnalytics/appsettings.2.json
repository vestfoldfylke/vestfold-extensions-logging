{
  "Serilog": {
    "AzureLogAnalytics": {
      "ImmutableId": "immutable-id",
      "StreamName": "stream-name",
      "TenantId": "tenant-id",
      "MinimumLevel": "Warning",
      "BatchSize": 500,
      "BufferSize": 5000,
      "PeriodSeconds": 100
    },
    "MinimumLevel": {
      "Override": {
        "Microsoft.Hosting": "Error"
      }
    }
  }
}